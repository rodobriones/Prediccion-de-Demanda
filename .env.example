# ============================================================
# Variables PÚBLICAS (frontend, web/.env) — van en el bundle,
# la anon key es pública por diseño; RLS protege los datos.
# ============================================================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...
VITE_API_URL=https://tu-app.vercel.app

# ============================================================
# Variables SECRETAS (server-side: Vercel env vars y GitHub
# Actions secrets). NUNCA con prefijo VITE_, NUNCA en el
# frontend, NUNCA commiteadas.
# ============================================================
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service_role...
# JWT secret del proyecto (Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=super-secret-jwt-token
# Origin permitido para CORS en /api/predict (dominio del frontend)
FRONTEND_ORIGIN=https://tu-app.vercel.app
